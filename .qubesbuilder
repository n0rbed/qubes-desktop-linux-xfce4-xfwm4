host-fc37:
  rpm:
    build:
    - xfwm4.spec
vm-bullseye:
  deb:
    build:
    - debian-pkg/debian
    source:
      commands:
      - '@PLUGINS_DIR@/source_deb/scripts/debian-quilt @SOURCE_DIR@/series-debian.conf @BUILD_DIR@/debian/patches'
vm-jammy:
  deb:
    build:
    - debian-pkg/debian
    source:
      commands:
      - '@PLUGINS_DIR@/source_deb/scripts/debian-quilt @SOURCE_DIR@/series-debian.conf @BUILD_DIR@/debian/patches'

source:
  files:
  - url: https://archive.xfce.org/src/xfce/xfwm4/4.16/xfwm4-@VERSION@.tar.bz2
    sha512: xfwm4-@VERSION@.tar.bz2.sha512
